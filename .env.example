# Perfect Web Clone - Environment Variables

# ====================================
# Backend Configuration
# ====================================

# Anthropic API Key (required for AI Agent)
ANTHROPIC_API_KEY=sk-ant-...

# Backend server port
PORT=5100

# ====================================
# Frontend Configuration
# ====================================

# Backend API URL (used by most frontend modules)
NEXT_PUBLIC_API_URL=http://localhost:5100

# Backend URL (used by agent/codegen modules, package.json script)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:5100

# WebSocket URL (for Agent communication)
NEXT_PUBLIC_WS_URL=ws://localhost:5100

# ====================================
# Optional Configuration
# ====================================

# OpenAI API Key (optional, for GPT-4 fallback)
# OPENAI_API_KEY=sk-...

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
